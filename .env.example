# =============================================================================
# Unified Logistics Data Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# -----------------------------------------------------------------------------
# Spark
# -----------------------------------------------------------------------------
SPARK_MASTER=local[*]
# For cluster mode: spark://spark-master:7077

# -----------------------------------------------------------------------------
# PostgreSQL (for Airflow metadata)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=logistics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# MinIO (S3-compatible storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=logistics-data

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:postgres@localhost:5432/airflow
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-here

# -----------------------------------------------------------------------------
# Alerting (optional)
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Data Paths
# -----------------------------------------------------------------------------
PROJECT_ROOT=/path/to/unified-logistics-platform
DATA_DIR=${PROJECT_ROOT}/data

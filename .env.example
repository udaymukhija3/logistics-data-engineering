# =============================================================================
# Unified Logistics Data Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# -----------------------------------------------------------------------------
# Spark
# -----------------------------------------------------------------------------
SPARK_MASTER=local[*]
# For cluster mode: spark://spark-master:7077

# -----------------------------------------------------------------------------
# PostgreSQL (for Airflow metadata)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=logistics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# -----------------------------------------------------------------------------
# MinIO (S3-compatible storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=logistics-data

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:${POSTGRES_PASSWORD}@localhost:5432/airflow
AIRFLOW__CORE__FERNET_KEY=change-me
AIRFLOW__WEBSERVER__SECRET_KEY=change-me
AIRFLOW_ADMIN_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Alerting (optional)
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Data Paths
# -----------------------------------------------------------------------------
PROJECT_ROOT=/path/to/unified-logistics-platform
DATA_DIR=${PROJECT_ROOT}/data
LOGISTICS_DUCKDB_PATH=${PROJECT_ROOT}/data/warehouse/logistics.duckdb
